    fontsize=FS_LEGEND,
    frameon=False,
    columnspacing=1.2,
    handlelength=2.6,
    handleheight=0.85,
    handletextpad=0.6,
    bbox_to_anchor=(0.5, 0.0),
)

fig.tight_layout(rect=[0, 0.14, 1, 1])

fig.savefig("ghg_pie_charts.png", dpi=DPI, bbox_inches="tight")
fig.savefig("ghg_pie_charts.svg", format="svg", bbox_inches="tight")
