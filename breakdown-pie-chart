chosen = next((f for f in font_pref if f in available), "DejaVu Sans")
print(f"Font: {chosen}")

plt.rcParams.update({
    "font.family": chosen,
    "mathtext.fontset": "custom",
    "mathtext.rm": chosen,
    "mathtext.it": chosen,
    "mathtext.bf": chosen,
})

plt.rcParams['svg.fonttype'] = 'none'

# ── Okabe–Ito palette ─────────────────────────────────────────────────────────
oi_colors = [
    "#E69F00",  # orange          — equipment manufacturing
    "#56B4E9",  # sky blue        — equipment installation
    "#009E73",  # bluish green    — miscellaneous
    "#F0E442",  # yellow          — site development
    "#0072B2",  # blue            — additional piping
    "#D55E00",  # vermillion      — field emissions
    "#CC79A7",  # reddish purple  — warehouse development
]

categories = [
    "Equipment manufacturing",
    "Equipment installation",
    "Miscellaneous",
    "Site development",
    "Additional piping",
    "Field emissions",
    "Warehouse development",
]

# ── Precise values from CSV (kg CO₂ eq) ───────────────────────────────────────
insitu_kg = [
    40073797.15,   # Equipment manufacturing
    48518604.88,   # Equipment installation
    9327505.549,   # Miscellaneous
    4553814.991,   # Site development
    4553814.991,   # Additional piping
    2852586.648,   # Field emissions
    1971217.483,   # Warehouse development
]
exsitu_kg = [
    47657874.56,   # Equipment manufacturing
